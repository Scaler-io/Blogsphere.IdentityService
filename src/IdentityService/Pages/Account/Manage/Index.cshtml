@page
@model IdentityService.Pages.Account.Manage.Index
@{
    ViewData["Title"] = "Account Settings";
    Layout = "_SinglePageLayout";
}

<div class="reset-password-container">
    <div class="reset-password-left-section">
        <div class="gradient-overlay"></div>
        <div class="content-wrapper">
            <div class="brand-section">
                <h1 class="brand-title">Blogsphere</h1>
                <p class="brand-subtitle">Identity Service</p>
            </div>

            <div class="illustration-container">
                <svg width="320" height="280" viewBox="0 0 320 280" fill="none" xmlns="http://www.w3.org/2000/svg" class="reset-password-illustration">
                    <circle cx="160" cy="140" r="120" fill="rgba(255, 255, 255, 0.1)" />
                    <circle cx="160" cy="140" r="90" fill="rgba(255, 255, 255, 0.05)" />

                    <!-- User with gear -->
                    <circle cx="160" cy="110" r="18" fill="rgba(255, 255, 255, 0.9)" stroke="rgba(255, 255, 255, 1)" stroke-width="2"/>
                    <circle cx="160" cy="106" r="7" fill="#0033cc"/>
                    <path d="M140 148C140 135 148 128 160 128C172 128 180 135 180 148" fill="rgba(255, 255, 255, 0.9)" stroke="rgba(255, 255, 255, 1)" stroke-width="2"/>
                    <!-- Gear -->
                    <circle cx="185" cy="155" r="12" fill="none" stroke="rgba(255, 255, 255, 0.9)" stroke-width="2"/>
                    <circle cx="185" cy="155" r="5" fill="#0033cc"/>
                    <line x1="185" y1="141" x2="185" y2="145" stroke="rgba(255, 255, 255, 0.9)" stroke-width="2" stroke-linecap="round"/>
                    <line x1="185" y1="165" x2="185" y2="169" stroke="rgba(255, 255, 255, 0.9)" stroke-width="2" stroke-linecap="round"/>
                    <line x1="171" y1="155" x2="175" y2="155" stroke="rgba(255, 255, 255, 0.9)" stroke-width="2" stroke-linecap="round"/>
                    <line x1="195" y1="155" x2="199" y2="155" stroke="rgba(255, 255, 255, 0.9)" stroke-width="2" stroke-linecap="round"/>

                    <!-- Floating elements -->
                    <circle cx="100" cy="100" r="4" fill="rgba(255, 230, 0, 0.8)" />
                    <circle cx="220" cy="120" r="3" fill="rgba(255, 230, 0, 0.6)" />
                    <circle cx="80" cy="180" r="5" fill="rgba(255, 230, 0, 0.7)" />
                    <circle cx="240" cy="180" r="4" fill="rgba(255, 230, 0, 0.5)" />

                    <!-- Connection lines -->
                    <path d="M100 100L160 140L220 120" stroke="rgba(255, 255, 255, 0.3)" stroke-width="1" stroke-dasharray="3,3"/>
                    <path d="M80 180L160 140L240 180" stroke="rgba(255, 255, 255, 0.3)" stroke-width="1" stroke-dasharray="3,3"/>
                </svg>
            </div>

            <div class="feature-text">
                <h3>Account Settings</h3>
                <p>Manage your security preferences and recovery options.</p>
            </div>
        </div>
    </div>

    <div class="reset-password-right-section">
        <div class="form-container">
            <div class="back-nav">
                <a class="back-nav-link" href="@Model.ReturnUrl">&larr; Back to App</a>
            </div>
            <div class="form-header">
                <h2>Account Settings</h2>
                <p>Manage security and recovery for <strong>@Model.UserEmail</strong></p>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="manage-status-message">@Model.StatusMessage</div>
            }

            <div class="manage-card-list">
                <a class="manage-card" asp-page="/Account/Manage/TwoFactor/Index"
                   asp-route-returnUrl="@Model.ReturnUrl" asp-route-clientId="@Model.ClientId">
                    <div class="manage-card-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </div>
                    <div class="manage-card-body">
                        <span class="manage-card-title">Two-factor authentication</span>
                        <span class="manage-card-desc">
                            @if (Model.TwoFactorEnabled)
                            {
                                <span class="manage-badge manage-badge--on">Enabled</span>
                            }
                            else
                            {
                                <span class="manage-badge manage-badge--off">Disabled</span>
                            }
                        </span>
                    </div>
                    <span class="manage-card-arrow">&rsaquo;</span>
                </a>

                <a class="manage-card" asp-page="/Account/Manage/Phone/Index"
                   asp-route-returnUrl="@Model.ReturnUrl" asp-route-clientId="@Model.ClientId">
                    <div class="manage-card-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
                            <line x1="12" y1="18" x2="12.01" y2="18"/>
                        </svg>
                    </div>
                    <div class="manage-card-body">
                        <span class="manage-card-title">Recovery phone</span>
                        <span class="manage-card-desc">
                            @if (!string.IsNullOrEmpty(Model.MaskedPhone))
                            {
                                <span>@Model.MaskedPhone</span>
                                @if (Model.PhoneConfirmed)
                                {
                                    <span class="manage-badge manage-badge--on">Verified</span>
                                }
                                else
                                {
                                    <span class="manage-badge manage-badge--off">Not verified</span>
                                }
                            }
                            else
                            {
                                <span class="manage-hint">Not set</span>
                            }
                        </span>
                    </div>
                    <span class="manage-card-arrow">&rsaquo;</span>
                </a>
            </div>
        </div>
    </div>
</div>
